# ─── Local Development ───────────────────────────────────────────────────────

# Path to your Firebase service-account key JSON file (local dev only)
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# Your Firebase Web API Key (Project Settings → General → Your apps → apiKey)
FIREBASE_API_KEY=your_firebase_web_api_key_here

# Flask session secret
SECRET_KEY=change-this-to-a-long-random-string-in-production


# ─── Production / Vercel ─────────────────────────────────────────────────────
# On Vercel, set these 3 environment variables in the Vercel Dashboard:
#
#   FIREBASE_CREDENTIALS_JSON  →  paste the ENTIRE contents of firebase_credentials.json
#   FIREBASE_API_KEY           →  same Web API Key as above
#   SECRET_KEY                 →  a long random secret string
#
# FIREBASE_CREDENTIALS_PATH is NOT needed on Vercel (FIREBASE_CREDENTIALS_JSON takes priority).
